---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Nav from '../components/Nav.astro';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const { title, description, pubDate, category, tags, readTime, slug } = Astro.props;

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.id !== slug && p.data.category === category)
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  mindset: '🧠 Mindset',
  frameworks: '🗺️ Frameworks & GTM',
  tools: '🛠️ Tools & Tech',
  career: '💼 Career',
  'soft-skills': '🤝 Soft Skills',
};

const base = '';

const dateStr = pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Chickentrepreneur</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Serif+Text:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --bg: #ffffff;
      --bg-alt: #f7f7f7;
      --text: #1f2a44;
      --text-secondary: rgba(31,42,68,0.7);
      --text-muted: rgba(31,42,68,0.45);
      --accent: #8b1413;
      --accent-light: rgba(139,20,19,0.07);
      --border: #dedfe3;
      --surface: #ffffff;
      --search-bg: #f7f7f7;
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      margin: 0;
      padding: 0;
      font-size: 16px;
      line-height: 1.8;
    }
    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }
    h1, h2, h3 {
      font-family: 'DM Serif Display', serif;
      font-weight: 400;
      line-height: 1.2;
    }
    strong, b { font-weight: 600; }

    /* Nav */
    nav { border-bottom: 0.5px solid var(--border); padding: 0 1.5rem; }
    .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 18px; color: var(--text); font-weight: 400; }
    .nav-right { display: flex; gap: 0.5rem; }
    .btn-pill {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      padding: 5px 14px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.15);
      background: transparent;
      color: var(--text);
      text-decoration: none;
    }
    .btn-ghost { background: transparent; color: var(--text-secondary); border-color: rgba(0,0,0,0.1); }

    /* Article */
    .article-wrap { max-width: 760px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

    .article-header { margin-bottom: 2rem; }
    .cat-pill {
      display: inline-block;
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 7px;
      background: var(--accent-light);
      border: 1px solid rgba(139,20,19,0.15);
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .article-header h1 { font-size: 36px; margin: 0 0 0.75rem; }
    .article-meta { display: flex; gap: 1rem; font-size: 12px; color: var(--text-muted); }

    /* Body */
    .article-body { color: var(--text-secondary); }
    .article-body p { margin-bottom: 1.25rem; }
    .article-body h2 { font-size: 26px; margin: 2rem 0 0.75rem; color: var(--text); }
    .article-body h3 { font-size: 20px; margin: 1.5rem 0 0.5rem; color: var(--text); }
    .article-body blockquote {
      border-left: 2px solid var(--accent);
      padding-left: 1.25rem;
      margin: 1.5rem 0;
      font-family: 'DM Serif Text', serif;
      font-style: italic;
      font-size: 20px;
      color: var(--text);
    }

    /* Related */
    .related-section { margin-top: 3rem; padding-top: 2rem; border-top: 0.5px solid var(--border); }
    .related-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      font-weight: 500;
      margin-bottom: 1rem;
    }
    .related-list { display: flex; flex-direction: column; gap: 0; }
    .related-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 0;
      border-bottom: 0.5px solid var(--border);
      text-decoration: none;
      color: var(--text);
    }
    .related-item:first-child { border-top: 0.5px solid var(--border); }
    .related-item:hover { background: var(--bg-alt); }
    .related-title { flex: 1; font-size: 14px; color: var(--text); }
    .related-time { font-size: 12px; color: var(--text-muted); }

    /* Footer */
    footer {
      border-top: 0.5px solid var(--border);
      text-align: center;
      padding: 1.5rem;
      font-size: 13px;
      color: var(--text-muted);
    }
  </style>
</head>
<body>

<Nav />

<!-- Article -->
<div class="article-wrap">
  <div class="article-header">
    <span class="cat-pill">{categoryLabels[category] ?? category}</span>
    <h1>{title}</h1>
    <div class="article-meta">
      <span>{dateStr}</span>
      <span>{readTime} min read</span>
    </div>
  </div>

  <div class="article-body" id="article-body">
    <slot />
  </div>

  {related.length > 0 && (
    <div class="related-section">
      <p class="related-label">Related concepts</p>
      <div class="related-list">
        {related.map((p) => (
          <a href={`${base}/blog/${p.id}`} class="related-item">
            <span class="cat-pill" style="flex-shrink:0">{categoryLabels[p.data.category] ?? p.data.category}</span>
            <span class="related-title">{p.data.title}</span>
            <span class="related-time">{p.data.readTime} min</span>
          </a>
        ))}
      </div>
    </div>
  )}
</div>

<!-- Footer -->
<footer>
  🐣 Chickentrepreneur · by Constantin Claes · Twice a month
</footer>

<script define:vars={{ allPostsData: allPosts.map(p => ({ id: p.id, title: p.data.title, base })) }}>
  // Auto-link article body text that matches other article titles
  const articleBody = document.getElementById('article-body');
  if (articleBody) {
    const walker = document.createTreeWalker(articleBody, NodeFilter.SHOW_TEXT);
    const nodesToProcess = [];
    let node;
    while ((node = walker.nextNode())) {
      if (node.parentElement?.tagName !== 'A') {
        nodesToProcess.push(node);
      }
    }
    nodesToProcess.forEach((textNode) => {
      let html = textNode.textContent ?? '';
      allPostsData.forEach(({ id, title }) => {
        if (html.includes(title)) {
          html = html.split(title).join(`<a href="${base}/blog/${id}" style="color:#555555">${title}</a>`);
        }
      });
      if (html !== textNode.textContent) {
        const span = document.createElement('span');
        span.innerHTML = html;
        textNode.parentNode?.replaceChild(span, textNode);
      }
    });
  }
</script>

<script>
  // ── Bionic Reading ────────────────────────────────────
  function applyBionic(container: Element) {
    const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const p = node.parentElement;
        if (!p) return NodeFilter.FILTER_REJECT;
        if (p.closest('h1,h2,h3,h4,code,pre,a,script,style')) return NodeFilter.FILTER_REJECT;
        if (p.tagName === 'B' || p.tagName === 'STRONG') return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }
    });
    const nodes: Text[] = [];
    let n: Node | null;
    while ((n = walker.nextNode())) nodes.push(n as Text);
    nodes.forEach(tn => {
      const text = tn.textContent || '';
      if (!text.trim()) return;
      const html = text.replace(/\b([A-Za-z\u00C0-\u00FF]{2,})\b/g, w => {
        const half = Math.ceil(w.length / 2);
        return `<b>${w.slice(0, half)}</b>${w.slice(half)}`;
      });
      if (html !== text) {
        const span = document.createElement('span');
        span.innerHTML = html;
        tn.parentNode?.replaceChild(span, tn);
      }
    });
  }
  const body = document.getElementById('article-body');
  if (body) applyBionic(body);
</script>

</body>
</html>

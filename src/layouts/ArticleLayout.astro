---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const { title, description, pubDate, category, tags, readTime, slug } = Astro.props;

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.id !== slug && p.data.category === category)
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  mindset: '🧠 Mindset',
  frameworks: '🗺️ Frameworks & GTM',
  tools: '🛠️ Tools & Tech',
  career: '💼 Career',
  'soft-skills': '🤝 Soft Skills',
};

const base = '/chick_app';

const dateStr = pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Chickentrepreneur</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --bg: #FDFAF4;
      --text: #2C2416;
      --text-secondary: #7A6A52;
      --text-muted: #B8A88A;
      --accent: #C4995A;
      --accent-light: #F5EDDA;
      --border: #E8D5A3;
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      padding: 0;
      font-size: 16px;
      line-height: 1.8;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    h1, h2, h3 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500;
      line-height: 1.2;
    }
    strong, b { font-weight: 500; }

    /* Nav */
    nav { border-bottom: 0.5px solid var(--border); padding: 0 1.5rem; }
    .nav-inner {
      max-width: 720px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: var(--text); font-weight: 500; }
    .nav-right { display: flex; gap: 0.5rem; }
    .btn-pill {
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      padding: 5px 14px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--accent-light);
      color: var(--text);
      text-decoration: none;
    }
    .btn-ghost { background: transparent; color: var(--text-secondary); }

    /* Article */
    .article-wrap { max-width: 680px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

    .article-header { margin-bottom: 2rem; }
    .cat-pill {
      display: inline-block;
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 999px;
      background: var(--accent-light);
      border: 1px solid var(--border);
      color: var(--text-secondary);
      margin-bottom: 0.75rem;
    }
    .article-header h1 { font-size: 36px; margin: 0 0 0.75rem; }
    .article-meta { display: flex; gap: 1rem; font-size: 12px; color: var(--text-muted); }

    /* Body */
    .article-body { color: var(--text-secondary); }
    .article-body p { margin-bottom: 1.25rem; }
    .article-body h2 { font-size: 26px; margin: 2rem 0 0.75rem; color: var(--text); }
    .article-body h3 { font-size: 20px; margin: 1.5rem 0 0.5rem; color: var(--text); }
    .article-body blockquote {
      border-left: 2px solid var(--border);
      padding-left: 1.25rem;
      margin: 1.5rem 0;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 20px;
      color: var(--text);
    }

    /* Related */
    .related-section { margin-top: 3rem; padding-top: 2rem; border-top: 0.5px solid var(--border); }
    .related-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      font-weight: 500;
      margin-bottom: 1rem;
    }
    .related-list { display: flex; flex-direction: column; gap: 0; }
    .related-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 0;
      border-bottom: 0.5px solid var(--border);
      text-decoration: none;
    }
    .related-item:first-child { border-top: 0.5px solid var(--border); }
    .related-title { flex: 1; font-size: 14px; color: var(--text); }
    .related-time { font-size: 12px; color: var(--text-muted); }

    /* Footer */
    footer {
      border-top: 0.5px solid var(--border);
      text-align: center;
      padding: 1.5rem;
      font-size: 13px;
      color: var(--text-muted);
    }
  </style>
</head>
<body>

<!-- Nav -->
<nav>
  <div class="nav-inner">
    <a href={`${base}/`} class="nav-logo">🐣 Chickentrepreneur</a>
    <div class="nav-right">
      <a href={`${base}/about`} class="btn-pill">About</a>
      <a href={`${base}/`} class="btn-ghost btn-pill">Learn ↓</a>
    </div>
  </div>
</nav>

<!-- Article -->
<div class="article-wrap">
  <div class="article-header">
    <span class="cat-pill">{categoryLabels[category] ?? category}</span>
    <h1>{title}</h1>
    <div class="article-meta">
      <span>{dateStr}</span>
      <span>{readTime} min read</span>
    </div>
  </div>

  <div class="article-body" id="article-body">
    <slot />
  </div>

  {related.length > 0 && (
    <div class="related-section">
      <p class="related-label">Related concepts</p>
      <div class="related-list">
        {related.map((p) => (
          <a href={`${base}/blog/${p.id}`} class="related-item">
            <span class="cat-pill" style="flex-shrink:0">{categoryLabels[p.data.category] ?? p.data.category}</span>
            <span class="related-title">{p.data.title}</span>
            <span class="related-time">{p.data.readTime} min</span>
          </a>
        ))}
      </div>
    </div>
  )}
</div>

<!-- Footer -->
<footer>
  🐣 Chickentrepreneur · by Constantin Claes · Twice a month
</footer>

<script define:vars={{ allPostsData: allPosts.map(p => ({ id: p.id, title: p.data.title, base })) }}>
  // Auto-link article body text that matches other article titles
  const articleBody = document.getElementById('article-body');
  if (articleBody) {
    const walker = document.createTreeWalker(articleBody, NodeFilter.SHOW_TEXT);
    const nodesToProcess = [];
    let node;
    while ((node = walker.nextNode())) {
      if (node.parentElement?.tagName !== 'A') {
        nodesToProcess.push(node);
      }
    }
    nodesToProcess.forEach((textNode) => {
      let html = textNode.textContent ?? '';
      allPostsData.forEach(({ id, title }) => {
        if (html.includes(title)) {
          html = html.split(title).join(`<a href="${base}/blog/${id}" style="color:#C4995A">${title}</a>`);
        }
      });
      if (html !== textNode.textContent) {
        const span = document.createElement('span');
        span.innerHTML = html;
        textNode.parentNode?.replaceChild(span, textNode);
      }
    });
  }
</script>

</body>
</html>

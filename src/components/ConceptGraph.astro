---
interface Props {
  postsJson: string;
}
const { postsJson } = Astro.props;
---

<div class="cg-wrap">
  <canvas id="cg-canvas"></canvas>

  <!-- Article panel (slides in on node click) -->
  <div class="cg-panel" id="cg-panel">
    <div class="cg-panel-head">
      <div>
        <div class="cg-panel-cat" id="cg-panel-cat"></div>
        <div class="cg-panel-title" id="cg-panel-title"></div>
      </div>
      <button class="cg-panel-close" id="cg-panel-close">×</button>
    </div>
    <div class="cg-panel-articles" id="cg-panel-articles"></div>
  </div>

  <div class="cg-hint" id="cg-hint">Drag to move · Click to explore</div>
</div>

<script type="application/json" id="cg-posts" set:text={postsJson}></script>

<style>
  .cg-wrap {
    position: relative;
    width: 100%;
    height: 320px;
    border-radius: 12px;
    overflow: hidden;
    background: #FAF7F0;
    border: 1px solid #E8D5A3;
  }
  #cg-canvas {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
  }
  .cg-hint {
    position: absolute; bottom: 8px; left: 50%;
    transform: translateX(-50%);
    font-family: 'DM Sans', sans-serif; font-size: 10px;
    color: #B8A88A; pointer-events: none; white-space: nowrap;
    transition: opacity 0.3s;
  }
  /* Panel */
  .cg-panel {
    position: absolute; top: 0; right: 0;
    width: 230px; height: 100%;
    background: rgba(253,250,244,0.97);
    border-left: 1px solid #E8D5A3;
    border-radius: 0 12px 12px 0;
    display: flex; flex-direction: column;
    padding: 14px 14px 10px;
    transform: translateX(100%);
    transition: transform 0.22s cubic-bezier(.4,0,.2,1);
    z-index: 30; overflow: hidden;
  }
  .cg-panel.open { transform: translateX(0); }
  .cg-panel-head {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 8px;
    margin-bottom: 12px;
    border-bottom: 0.5px solid #E8D5A3; padding-bottom: 10px;
  }
  .cg-panel-cat {
    font-family: 'DM Sans', sans-serif; font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: #C4995A; margin-bottom: 2px;
  }
  .cg-panel-title {
    font-family: 'Cormorant Garamond', serif; font-size: 18px;
    color: #2C2416; line-height: 1.2;
  }
  .cg-panel-close {
    background: none; border: none; font-size: 18px;
    color: #B8A88A; cursor: pointer; padding: 0; line-height: 1;
    flex-shrink: 0; margin-top: -2px;
  }
  .cg-panel-close:hover { color: #2C2416; }
  .cg-panel-articles { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 6px; }
  .cg-article {
    display: block; padding: 8px 10px; border-radius: 8px;
    border: 1px solid #E8D5A3; background: #FDFAF4;
    text-decoration: none; transition: background 0.12s, border-color 0.12s;
  }
  .cg-article:hover { background: #F5EDDA; border-color: #C4995A; }
  .cg-article-title {
    font-family: 'DM Sans', sans-serif; font-size: 12px;
    font-weight: 500; color: #2C2416; margin-bottom: 4px; line-height: 1.4;
  }
  .cg-article-meta { display: flex; align-items: center; gap: 6px; }
  .cg-article-cat {
    font-size: 9px; padding: 1px 7px; border-radius: 999px;
    background: #F5EDDA; border: 1px solid #E8D5A3; color: #7A6A52;
  }
  .cg-article-time { font-size: 10px; color: #B8A88A; }
  .cg-no-articles {
    font-family: 'DM Sans', sans-serif; font-size: 12px;
    color: #B8A88A; font-style: italic; padding: 4px 0;
  }
</style>

<script>
  // ── Data ──────────────────────────────────────────────
  interface Post {
    id: string; title: string; description: string;
    category: string; tags: string[]; readTime: number;
  }
  const POSTS: Post[] = JSON.parse(
    (document.getElementById('cg-posts') as HTMLScriptElement).text
  );

  const CAT_LABELS: Record<string, string> = {
    mindset: '🧠 Mindset', frameworks: '🗺️ Frameworks',
    tools: '🛠️ Tools', career: '💼 Career', 'soft-skills': '🤝 Soft Skills',
  };
  const CAT_COLORS: Record<string, string> = {
    mindset: '#C4995A', frameworks: '#7A6A52',
    career: '#B8A88A', 'soft-skills': '#A0806A',
  };

  // ── Canvas setup ──────────────────────────────────────
  const canvas = document.getElementById('cg-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, dpr = 1;

  // ── Nodes & edges ─────────────────────────────────────
  interface Node {
    id: string; label: string; cat: string; article?: string;
    x: number; y: number; vx: number; vy: number;
    w: number; h: number; fx: number; fy: number;
  }
  const NODES: Node[] = [
    { id: 'surface-luck',   label: 'Surface luck',      cat: 'frameworks',   article: '/blog/surface-luck',      x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'speed-velocity', label: 'Speed vs. velocity', cat: 'mindset',     article: '/blog/speed-vs-velocity', x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: '99-done',        label: '99% done',           cat: 'soft-skills', article: '/blog/99-percent-done',   x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'pmf',            label: 'PMF',                cat: 'frameworks',  x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'gtm',            label: 'GTM',                cat: 'frameworks',  x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'equity',         label: 'Equity',             cat: 'career',      x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'compounding',    label: 'Compounding',        cat: 'mindset',     x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'operator',       label: 'Operator mindset',   cat: 'mindset',     x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'networking',     label: 'Networking',         cat: 'frameworks',  x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'communication',  label: 'Communication',      cat: 'soft-skills', x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
    { id: 'direction',      label: 'Direction',          cat: 'mindset',     x:0,y:0,vx:0,vy:0,w:0,h:28,fx:0,fy:0 },
  ];
  const EDGES: [number, number][] = [
    [0,8],[0,4],[1,10],[1,7],[2,9],[2,7],[3,4],[7,6],[6,5],[10,7],[8,6],[0,6],[1,6],
  ];

  // ── Articles per node ─────────────────────────────────
  function getNodeArticles(node: Node): Post[] {
    const nodeTagMap: Record<string, string[]> = {
      'surface-luck':   ['luck','networking','action'],
      'networking':     ['networking'],
      'communication':  ['communication','adoption'],
      'direction':      ['direction','focus','strategy'],
      'compounding':    ['compounding'],
      'gtm':            ['gtm','go-to-market','marketing'],
      'equity':         ['equity'],
      'operator':       ['operator'],
      'pmf':            ['pmf'],
    };
    const extraTags = nodeTagMap[node.id] || [];
    const seen = new Set<string>();
    const results: Post[] = [];
    // Direct article first
    if (node.article) {
      const slug = node.article.replace('/blog/', '');
      const p = POSTS.find(p => p.id === slug);
      if (p) { seen.add(p.id); results.push(p); }
    }
    // Same category
    POSTS.forEach(p => {
      if (!seen.has(p.id) && p.category === node.cat) {
        seen.add(p.id); results.push(p);
      }
    });
    // Tag matches
    POSTS.forEach(p => {
      if (!seen.has(p.id) && p.tags.some(t => extraTags.includes(t.toLowerCase()))) {
        seen.add(p.id); results.push(p);
      }
    });
    return results;
  }

  // ── Panel ─────────────────────────────────────────────
  const panel       = document.getElementById('cg-panel')!;
  const panelTitle  = document.getElementById('cg-panel-title')!;
  const panelCat    = document.getElementById('cg-panel-cat')!;
  const panelArts   = document.getElementById('cg-panel-articles')!;
  const panelClose  = document.getElementById('cg-panel-close')!;
  const hint        = document.getElementById('cg-hint')!;

  function openPanel(node: Node) {
    panelCat.textContent   = CAT_LABELS[node.cat] ?? node.cat;
    panelTitle.textContent = node.label;
    const arts = getNodeArticles(node);
    if (arts.length === 0) {
      panelArts.innerHTML = '<p class="cg-no-articles">No articles yet — coming soon.</p>';
    } else {
      panelArts.innerHTML = arts.map(p =>
        `<a href="/blog/${p.id}" class="cg-article">
          <div class="cg-article-title">${p.title}</div>
          <div class="cg-article-meta">
            <span class="cg-article-cat">${CAT_LABELS[p.category] ?? p.category}</span>
            <span class="cg-article-time">${p.readTime} min read</span>
          </div>
        </a>`
      ).join('');
    }
    panel.classList.add('open');
    hint.style.opacity = '0';
  }

  function closePanel() {
    panel.classList.remove('open');
    hint.style.opacity = '1';
  }

  panelClose.addEventListener('click', closePanel);

  // ── Physics ───────────────────────────────────────────
  function measureNodes() {
    ctx.font = '11px DM Sans, sans-serif';
    NODES.forEach(n => { n.w = Math.max(56, ctx.measureText(n.label).width + 24); });
  }
  function initPositions() {
    NODES.forEach((n, i) => {
      const angle = (i / NODES.length) * Math.PI * 2 - Math.PI / 2;
      const r = Math.min(W, H) * 0.32;
      n.x = W / 2 + r * Math.cos(angle);
      n.y = H / 2 + r * Math.sin(angle);
      n.vx = 0; n.vy = 0;
    });
  }
  function simulate(pinned: Node | null = null) {
    const REPULSE = 3500, SPRING_K = 0.045, REST = 120, GRAVITY = 0.012, DAMP = 0.86;
    NODES.forEach(n => { n.fx = 0; n.fy = 0; });
    for (let i = 0; i < NODES.length; i++) {
      for (let j = i + 1; j < NODES.length; j++) {
        const a = NODES[i], b = NODES[j];
        const dx = b.x-a.x, dy = b.y-a.y, d = Math.sqrt(dx*dx+dy*dy)+0.1;
        const f = REPULSE/(d*d), fx = f*dx/d, fy = f*dy/d;
        a.fx -= fx; a.fy -= fy; b.fx += fx; b.fy += fy;
      }
    }
    EDGES.forEach(([i,j]) => {
      const a = NODES[i], b = NODES[j];
      const dx = b.x-a.x, dy = b.y-a.y, d = Math.sqrt(dx*dx+dy*dy)+0.1;
      const f = SPRING_K*(d-REST), fx = f*dx/d, fy = f*dy/d;
      a.fx += fx; a.fy += fy; b.fx -= fx; b.fy -= fy;
    });
    NODES.forEach(n => {
      n.fx += (W/2-n.x)*GRAVITY;
      n.fy += (H/2-n.y)*GRAVITY;
    });
    NODES.forEach(n => {
      if (n === pinned) return;
      n.vx = (n.vx+n.fx)*DAMP; n.vy = (n.vy+n.fy)*DAMP;
      n.x += n.vx; n.y += n.vy;
      const px = n.w/2+8, py = n.h/2+8;
      n.x = Math.max(px, Math.min(W-px, n.x));
      n.y = Math.max(py, Math.min(H-py, n.y));
    });
  }

  // ── Draw ──────────────────────────────────────────────
  function pill(x: number, y: number, w: number, h: number) {
    const r = h/2;
    ctx.beginPath();
    ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y);
    ctx.arcTo(x+w,y,x+w,y+r,r); ctx.lineTo(x+w,y+h-r);
    ctx.arcTo(x+w,y+h,x+w-r,y+h,r); ctx.lineTo(x+r,y+h);
    ctx.arcTo(x,y+h,x,y+h-r,r); ctx.lineTo(x,y+r);
    ctx.arcTo(x,y,x+r,y,r); ctx.closePath();
  }

  let hoveredNode: Node | null = null;

  function draw() {
    ctx.clearRect(0, 0, W, H);
    EDGES.forEach(([i,j]) => {
      const a = NODES[i], b = NODES[j];
      ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
      ctx.strokeStyle = '#E8D5A3'; ctx.lineWidth = 1; ctx.stroke();
    });
    NODES.forEach(n => {
      const hov = n === hoveredNode;
      const color = CAT_COLORS[n.cat] || '#B8A88A';
      pill(n.x-n.w/2, n.y-n.h/2, n.w, n.h);
      ctx.fillStyle = hov ? '#F5EDDA' : '#FDFAF4'; ctx.fill();
      ctx.strokeStyle = hov ? '#C4995A' : color;
      ctx.lineWidth = hov ? 2 : 1; ctx.stroke();
      ctx.fillStyle = '#2C2416';
      ctx.font = `${n.article ? '500' : '400'} 11px 'DM Sans', sans-serif`;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(n.label, n.x, n.y);
      if (n.article) {
        const tw = ctx.measureText(n.label).width;
        ctx.beginPath();
        ctx.moveTo(n.x-tw/2, n.y+7); ctx.lineTo(n.x+tw/2, n.y+7);
        ctx.strokeStyle = hov ? '#C4995A' : color; ctx.lineWidth = 0.8; ctx.stroke();
      }
    });
  }

  // ── Interaction ───────────────────────────────────────
  let draggingNode: Node | null = null;
  let dragStartX = 0, dragStartY = 0;
  let hasDragged = false;
  let animId: number;

  function nodeAt(mx: number, my: number): Node | null {
    for (const n of NODES) {
      if (mx >= n.x-n.w/2 && mx <= n.x+n.w/2 &&
          my >= n.y-n.h/2 && my <= n.y+n.h/2) return n;
    }
    return null;
  }

  function getPos(e: MouseEvent | Touch): { mx: number; my: number } {
    const rect = canvas.getBoundingClientRect();
    return { mx: (e as MouseEvent).clientX - rect.left, my: (e as MouseEvent).clientY - rect.top };
  }

  // Mouse
  canvas.addEventListener('mousedown', (e) => {
    const { mx, my } = getPos(e);
    draggingNode = nodeAt(mx, my);
    if (draggingNode) { dragStartX = mx; dragStartY = my; hasDragged = false; }
  });
  canvas.addEventListener('mousemove', (e) => {
    const { mx, my } = getPos(e);
    if (draggingNode) {
      const dist = Math.sqrt((mx-dragStartX)**2 + (my-dragStartY)**2);
      if (dist > 4) hasDragged = true;
      draggingNode.x = mx; draggingNode.y = my;
      draggingNode.vx = 0; draggingNode.vy = 0;
      canvas.style.cursor = 'grabbing';
    } else {
      hoveredNode = nodeAt(mx, my);
      canvas.style.cursor = hoveredNode ? 'pointer' : 'default';
    }
  });
  canvas.addEventListener('mouseup', (e) => {
    if (draggingNode && !hasDragged) {
      openPanel(draggingNode);
    }
    draggingNode = null;
    const { mx, my } = getPos(e);
    hoveredNode = nodeAt(mx, my);
    canvas.style.cursor = hoveredNode ? 'pointer' : 'default';
  });
  canvas.addEventListener('mouseleave', () => {
    draggingNode = null; hoveredNode = null;
    canvas.style.cursor = 'default';
  });

  // Touch
  canvas.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    const rect = canvas.getBoundingClientRect();
    const mx = t.clientX-rect.left, my = t.clientY-rect.top;
    draggingNode = nodeAt(mx, my);
    if (draggingNode) { dragStartX = mx; dragStartY = my; hasDragged = false; e.preventDefault(); }
  }, { passive: false });
  canvas.addEventListener('touchmove', (e) => {
    if (!draggingNode) return;
    e.preventDefault();
    const t = e.touches[0];
    const rect = canvas.getBoundingClientRect();
    const mx = t.clientX-rect.left, my = t.clientY-rect.top;
    const dist = Math.sqrt((mx-dragStartX)**2 + (my-dragStartY)**2);
    if (dist > 4) hasDragged = true;
    draggingNode.x = mx; draggingNode.y = my;
    draggingNode.vx = 0; draggingNode.vy = 0;
  }, { passive: false });
  canvas.addEventListener('touchend', () => {
    if (draggingNode && !hasDragged) openPanel(draggingNode);
    draggingNode = null;
  });

  // ── Loop ──────────────────────────────────────────────
  function loop() {
    simulate(draggingNode);
    draw();
    animId = requestAnimationFrame(loop);
  }

  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W*dpr; canvas.height = H*dpr;
    ctx.scale(dpr, dpr);
    measureNodes();
  }
  function warmup(steps: number) {
    measureNodes(); initPositions();
    for (let i = 0; i < steps; i++) simulate();
  }

  resize(); warmup(200); loop();
  window.addEventListener('resize', () => {
    cancelAnimationFrame(animId); resize(); initPositions(); warmup(100); loop();
  });
</script>

---
---
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">🐣 Chickentrepreneur</a>
    <div class="nav-right">
      <a href="/about" class="btn-pill">About</a>
      <div class="dropdown-wrapper">
        <button class="btn-pill btn-ghost" tabindex="0">Learn ↓</button>
        <div class="dropdown-menu">
          <a href="/">🏠 Home</a>
          <div class="dropdown-divider"></div>
          <a href="/category/mindset">🧠 Mindset & Soft Skills</a>
          <a href="/category/frameworks">🗺️ Frameworks</a>
          <a href="/category/gtm">📈 GTM</a>
          <a href="/category/tools">🛠️ Tools & Tech</a>
          <a href="/category/career">💼 Career</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  nav {
    background: #1F487E;
    padding: 0 2rem;
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 58px;
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px;
    color: #F5DD72;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .nav-right { display: flex; gap: 0.5rem; align-items: center; }
  .btn-pill {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    padding: 5px 16px;
    border-radius: 999px;
    cursor: pointer;
    border: 1px solid rgba(36,123,160,0.4);
    background: rgba(36,123,160,0.15);
    color: #F5DD72;
    text-decoration: none;
    transition: background 0.12s, border-color 0.12s;
    white-space: nowrap;
  }
  .btn-pill:hover { background: rgba(36,123,160,0.28); border-color: rgba(36,123,160,0.7); }
  .btn-ghost { background: transparent; border-color: rgba(245,221,114,0.25); color: rgba(245,221,114,0.8); }
  .btn-ghost:hover { background: rgba(255,255,255,0.07); border-color: rgba(245,221,114,0.45); color: #F5DD72; }

  .dropdown-wrapper { position: relative; }
  .dropdown-menu {
    visibility: hidden; opacity: 0; pointer-events: none;
    transition: opacity 0.12s, visibility 0.12s;
    position: absolute; right: 0; top: 100%;
    background: #1F487E;
    border: 1px solid rgba(36,123,160,0.3);
    border-radius: 10px; padding: 6px; min-width: 210px;
    box-shadow: 0 8px 32px rgba(29,52,97,0.4);
    margin-top: 4px;
  }
  .dropdown-wrapper:hover .dropdown-menu,
  .dropdown-wrapper:focus-within .dropdown-menu {
    visibility: visible; opacity: 1; pointer-events: auto;
  }
  .dropdown-menu a {
    display: block; padding: 7px 12px;
    font-family: 'DM Sans', sans-serif; font-size: 13px;
    color: #F5DD72; border-radius: 6px; text-decoration: none;
    transition: background 0.1s;
  }
  .dropdown-menu a:hover { background: rgba(245,221,114,0.12); color: #F5DD72; }
  .dropdown-divider { height: 0.5px; background: rgba(245,221,114,0.2); margin: 4px 8px; }
</style>

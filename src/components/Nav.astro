---
---
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">🐣 Chickentrepreneur</a>
    <div class="nav-right">
      <a href="/about" class="btn-pill">About</a>
      <div class="dropdown-wrapper">
        <button class="btn-pill btn-ghost" tabindex="0">Learn ↓</button>
        <div class="dropdown-menu">
          <a href="/">🏠 Home</a>
          <div class="dropdown-divider"></div>
          <a href="/category/mindset">🧠 Mindset & Soft Skills</a>
          <a href="/category/frameworks">🗺️ Frameworks</a>
          <a href="/category/gtm">📈 GTM</a>
          <a href="/category/tools">🛠️ Tools & Tech</a>
          <a href="/category/career">💼 Career</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  nav {
    background: #ffffff;
    border-bottom: 1px solid #dedfe3;
    padding: 0 2rem;
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .nav-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 19px;
    color: #1f2a44;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .nav-right { display: flex; gap: 0.5rem; align-items: center; }
  .btn-pill {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    padding: 5px 16px;
    border-radius: 7px;
    cursor: pointer;
    border: 1px solid #dedfe3;
    background: transparent;
    color: #1f2a44;
    text-decoration: none;
    transition: background 0.12s, border-color 0.12s;
    white-space: nowrap;
  }
  .btn-pill:hover { background: #f7f7f7; border-color: rgba(31,42,68,0.25); }
  .btn-ghost { background: transparent; color: rgba(31,42,68,0.7); }
  .btn-ghost:hover { background: #f7f7f7; color: #1f2a44; }

  .dropdown-wrapper { position: relative; }
  .dropdown-menu {
    visibility: hidden; opacity: 0; pointer-events: none;
    transition: opacity 0.12s, visibility 0.12s;
    position: absolute; right: 0; top: 100%;
    background: #ffffff;
    border: 1px solid #dedfe3;
    border-radius: 7px; padding: 6px; min-width: 210px;
    box-shadow: 0 8px 24px rgba(31,42,68,0.1);
    margin-top: 4px;
  }
  .dropdown-wrapper:hover .dropdown-menu,
  .dropdown-wrapper:focus-within .dropdown-menu {
    visibility: visible; opacity: 1; pointer-events: auto;
  }
  .dropdown-menu a {
    display: block; padding: 7px 12px;
    font-family: 'Inter', sans-serif; font-size: 13px;
    color: #1f2a44; border-radius: 4px; text-decoration: none;
    transition: background 0.1s;
  }
  .dropdown-menu a:hover { background: #f7f7f7; }
  .dropdown-divider { height: 0.5px; background: #dedfe3; margin: 4px 8px; }
</style>

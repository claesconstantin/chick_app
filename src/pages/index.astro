---
import { getCollection } from 'astro:content';
import ConceptGraph from '../components/ConceptGraph.astro';
import Nav from '../components/Nav.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabels: Record<string, string> = {
  mindset: '🧠 Mindset',
  frameworks: '🗺️ Frameworks',
  tools: '🛠️ Tools & Tech',
  career: '💼 Career',
  'soft-skills': '🤝 Soft Skills',
};

const searchData = sortedPosts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  tags: p.data.tags,
  readTime: p.data.readTime,
}));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chickentrepreneur</title>
  <meta name="description" content="Fresh eyes on the startup world, seen from the inside." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --bg: #ffffff;
      --bg-dark: #000000;
      --text: #0a0a0a;
      --text-secondary: #555555;
      --text-muted: #888888;
      --accent: #a6d1ff;
      --accent-2: #e3dff2;
      --accent-3: #daf1de;
      --accent-light: rgba(166,209,255,0.25);
      --border: rgba(0,0,0,0.07);
      --surface: rgba(255,255,255,0.95);
      --search-bg: #f5f5f5;
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg);
      background-image: repeating-linear-gradient(transparent, transparent 27px, rgba(0,0,0,0.03) 27px, rgba(0,0,0,0.03) 28px);
      color: var(--text); margin: 0; padding: 0; font-size: 15px; line-height: 1.7;
    }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3 { font-family: 'Instrument Serif', serif; font-weight: 400; line-height: 1.2; }
    strong, b { font-weight: 500; }

    /* Hero */
    .hero { padding: 3rem 1.5rem 2rem; max-width: 960px; margin: 0 auto; }
    .pill-tag {
      display: inline-block; font-size: 11px;
      background: var(--accent-light); border: 1px solid rgba(166,209,255,0.5);
      color: var(--text-secondary); border-radius: 999px;
      padding: 3px 12px; margin-bottom: 1rem; letter-spacing: 0.02em;
    }
    .hero h1 { font-size: 48px; margin: 0 0 0.4rem; color: var(--text); }
    .hero-sub { font-size: 15px; color: var(--text-secondary); margin: 0 0 1.5rem; font-style: italic; }

    /* Search */
    .search-wrap { position: relative; margin-bottom: 1.5rem; }
    .search-bar {
      width: 100%; padding: 10px 18px; border-radius: 999px;
      border: 1px solid var(--border); background: var(--search-bg);
      font-family: 'Inter', sans-serif; font-size: 14px; color: var(--text); outline: none;
    }
    .search-bar::placeholder { color: var(--text-muted); }
    .search-bar:focus { border-color: rgba(166,209,255,0.8); }
    .search-results {
      display: none;
      position: absolute; top: calc(100% + 6px); left: 0; right: 0;
      background: var(--bg); border: 1px solid var(--border); border-radius: 12px;
      padding: 6px; z-index: 50; box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .search-result {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 8px 10px; border-radius: 8px; text-decoration: none; color: var(--text);
    }
    .search-result:hover { background: var(--accent-light); }
    .sr-cat {
      font-size: 10px; padding: 2px 8px; border-radius: 999px;
      background: var(--accent-light); border: 1px solid rgba(166,209,255,0.5);
      color: var(--text-secondary); white-space: nowrap; flex-shrink: 0;
    }
    .sr-title { flex: 1; font-size: 13px; }
    .sr-time { font-size: 11px; color: var(--text-muted); white-space: nowrap; }
    .search-empty { padding: 10px 12px; font-size: 13px; color: var(--text-muted); }

    /* Timer */
    .timer-zone { margin-bottom: 0.5rem; }
    .timer-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
    .timer-label { font-size: 14px; color: var(--text-secondary); }
    .timer-inline-input {
      font-family: 'Inter', sans-serif; font-size: 14px;
      width: 58px; padding: 3px 8px; text-align: center;
      border-radius: 8px; border: 1px solid var(--border);
      background: var(--search-bg); color: var(--text); outline: none;
      -moz-appearance: textfield;
    }
    .timer-inline-input::-webkit-outer-spin-button,
    .timer-inline-input::-webkit-inner-spin-button { -webkit-appearance: none; }
    .timer-inline-input:focus { border-color: rgba(166,209,255,0.8); }
    .timer-bottom { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.25rem; }
    .timer-display {
      font-family: 'Instrument Serif', serif; font-size: 32px;
      color: #0a0a0a; min-width: 80px;
    }
    .timer-start-stop {
      font-family: 'Inter', sans-serif; font-size: 13px;
      padding: 5px 16px; border-radius: 999px;
      border: 1px solid var(--border); background: transparent;
      color: var(--text-secondary); cursor: pointer; transition: all 0.12s;
    }
    .timer-start-stop:hover { background: var(--accent-light); border-color: rgba(166,209,255,0.8); color: var(--text); }
    .timer-start-stop.running { border-color: rgba(166,209,255,0.8); color: #0a0a0a; }
    .timer-note { font-size: 12px; color: var(--text-muted); margin: 0 0 2.5rem; }
    .notif-btn {
      font-size: 11px; color: var(--text-muted); background: none; border: none;
      cursor: pointer; text-decoration: underline; padding: 0; display: none;
    }

    /* Section labels */
    .section-label {
      font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text-muted); font-weight: 500; margin-bottom: 1rem;
    }

    /* Concept map */
    .concept-section { padding: 2rem 1.5rem; max-width: 960px; margin: 0 auto; }

    /* Categories grid */
    .categories-section { padding: 0 1.5rem 2rem; max-width: 960px; margin: 0 auto; }
    .categories-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
    .category-card {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 1rem; text-decoration: none;
      display: block; transition: border-color 0.12s, background 0.12s;
    }
    .category-card:hover { background: rgba(166,209,255,0.12); border-color: rgba(166,209,255,0.5); }
    .category-card.dashed { border-style: dashed; display: flex; align-items: center; justify-content: center; }
    .category-emoji { font-size: 20px; margin-bottom: 0.25rem; }
    .category-name { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 0.15rem; }
    .category-sub { font-size: 11px; color: var(--text-muted); }
    .category-coming { font-size: 12px; color: var(--text-muted); text-align: center; }

    /* Articles list */
    .articles-section { padding: 0 1.5rem 3rem; max-width: 960px; margin: 0 auto; }
    .article-row {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.85rem 0; border-bottom: 0.5px solid var(--border);
    }
    .article-row:first-child { border-top: 0.5px solid var(--border); }
    .cat-pill {
      font-size: 11px; padding: 3px 10px; border-radius: 999px;
      background: var(--accent-light); border: 1px solid rgba(166,209,255,0.5);
      color: var(--text-secondary); white-space: nowrap; flex-shrink: 0;
    }
    .article-title { flex: 1; font-size: 14px; color: var(--text); }
    .article-title:hover { text-decoration: underline; }
    .read-time { font-size: 12px; color: var(--text-muted); white-space: nowrap; flex-shrink: 0; }

    footer { border-top: 0.5px solid var(--border); text-align: center; padding: 1.5rem; font-size: 13px; color: var(--text-muted); }

    @media (max-width: 600px) {
      .hero h1 { font-size: 36px; }
      .categories-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

<Nav />

<!-- Hero -->
<div class="hero">
  <span class="pill-tag">Twice a month · Pure signal</span>
  <h1>Fresh eyes on the startup world, seen from the inside.</h1>
  <p class="hero-sub">Learn more than you earn.</p>

  <!-- Search -->
  <div class="search-wrap">
    <input class="search-bar" id="search-input" type="text" placeholder="What do you want to learn today?" autocomplete="off" />
    <div class="search-results" id="search-results"></div>
  </div>

  <!-- Timer -->
  <div class="timer-zone">
    <div class="timer-row">
      <span class="timer-label">I have</span>
      <input class="timer-inline-input" id="timer-input" type="number" value="5" min="0.5" max="180" step="0.5" />
      <span class="timer-label">minutes to learn</span>
    </div>
    <div class="timer-bottom">
      <span class="timer-display" id="timer-display">05:00</span>
      <button class="timer-start-stop" id="timer-start-stop">▶ Start</button>
    </div>
  </div>
  <p class="timer-note">
    1 minute of reading = 1 minute of learning.
    <button class="notif-btn" id="notif-btn">Enable notifications 🔔</button>
  </p>
</div>

<!-- Concept map -->
<div class="concept-section">
  <p class="section-label">Concept map</p>
  <ConceptGraph postsJson={JSON.stringify(searchData)} />
</div>

<!-- Categories grid -->
<div class="categories-section">
  <p class="section-label">Explore by category</p>
  <div class="categories-grid">
    <a href="/category/mindset" class="category-card">
      <div class="category-emoji">🧠</div>
      <div class="category-name">Mindset & Soft Skills</div>
      <div class="category-sub">Psychology · Leadership</div>
    </a>
    <a href="/category/frameworks" class="category-card">
      <div class="category-emoji">🗺️</div>
      <div class="category-name">Frameworks</div>
      <div class="category-sub">Mental models · Growth</div>
    </a>
    <a href="/category/gtm" class="category-card">
      <div class="category-emoji">📈</div>
      <div class="category-name">GTM</div>
      <div class="category-sub">Go-to-market · Sales</div>
    </a>
    <a href="/category/tools" class="category-card">
      <div class="category-emoji">🛠️</div>
      <div class="category-name">Tools & Tech</div>
      <div class="category-sub">Stack · Productivity</div>
    </a>
    <a href="/category/career" class="category-card">
      <div class="category-emoji">💼</div>
      <div class="category-name">Career</div>
      <div class="category-sub">Equity · Salary · Path</div>
    </a>
    <div class="category-card dashed">
      <p class="category-coming">More coming every week</p>
    </div>
  </div>
</div>

<!-- Latest articles -->
<div class="articles-section">
  <p class="section-label">Latest articles</p>
  {sortedPosts.map((post) => (
    <a href={`/blog/${post.id}`} class="article-row" style="display:flex;text-decoration:none;">
      <span class="cat-pill">{categoryLabels[post.data.category] ?? post.data.category}</span>
      <span class="article-title">{post.data.title}</span>
      <span class="read-time">{post.data.readTime} min read</span>
    </a>
  ))}
</div>

<footer>🐣 Chickentrepreneur · by Constantin Claes · Twice a month</footer>

<!-- Pass posts to client -->
<script type="application/json" id="posts-data" set:text={JSON.stringify(searchData)}></script>

<script>
  // ── Search ────────────────────────────────────────────
  const CAT_LABELS: Record<string, string> = {
    mindset: '🧠 Mindset', frameworks: '🗺️ Frameworks',
    tools: '🛠️ Tools', career: '💼 Career', 'soft-skills': '🤝 Soft Skills',
  };
  const POSTS: { id: string; title: string; description: string; category: string; tags: string[]; readTime: number }[] =
    JSON.parse((document.getElementById('posts-data') as HTMLScriptElement).text);

  function scorePost(p: typeof POSTS[0], q: string): number {
    const title = p.title.toLowerCase();
    const desc  = p.description.toLowerCase();
    const tags  = p.tags.map(t => t.toLowerCase());
    let s = 0;
    if (title === q)            s += 100;
    else if (title.startsWith(q)) s += 80;
    else if (title.includes(q))   s += 50;
    if (tags.includes(q))         s += 60;
    else if (tags.some(t => t.startsWith(q))) s += 40;
    else if (tags.some(t => t.includes(q)))   s += 20;
    if (desc.includes(q))         s += 10;
    return s;
  }

  const searchInput   = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLDivElement;

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    if (q.length < 2) { searchResults.style.display = 'none'; return; }
    const scored = POSTS
      .map(p => ({ ...p, score: scorePost(p, q) }))
      .filter(p => p.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 5);
    searchResults.innerHTML = scored.length === 0
      ? '<div class="search-empty">No results found.</div>'
      : scored.map(p =>
          `<a href="/blog/${p.id}" class="search-result">
            <span class="sr-cat">${CAT_LABELS[p.category] ?? p.category}</span>
            <span class="sr-title">${p.title}</span>
            <span class="sr-time">${p.readTime} min</span>
          </a>`).join('');
    searchResults.style.display = 'block';
  });
  document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target as Node) && !searchResults.contains(e.target as Node))
      searchResults.style.display = 'none';
  });

  // ── Timer ─────────────────────────────────────────────
  let timeLeft = 5 * 60;
  let timerRunning = false;
  let interval: ReturnType<typeof setInterval> | null = null;

  const display      = document.getElementById('timer-display') as HTMLElement;
  const startStopBtn = document.getElementById('timer-start-stop') as HTMLButtonElement;
  const timerInput   = document.getElementById('timer-input') as HTMLInputElement;
  const notifBtn     = document.getElementById('notif-btn') as HTMLButtonElement;

  function fmt(s: number) {
    return `${Math.floor(s/60).toString().padStart(2,'0')}:${(s%60).toString().padStart(2,'0')}`;
  }
  display.textContent = fmt(timeLeft);

  timerInput.addEventListener('input', () => {
    const val = parseFloat(timerInput.value);
    if (!isNaN(val) && val > 0 && !timerRunning) {
      timeLeft = Math.round(val * 60);
      display.textContent = fmt(timeLeft);
    }
  });

  function playBeep() {
    try {
      const ac = new AudioContext();
      [0, 0.3, 0.6].forEach((delay, i) => {
        const osc = ac.createOscillator(), gain = ac.createGain();
        osc.connect(gain); gain.connect(ac.destination);
        osc.frequency.value = i === 2 ? 880 : 660; osc.type = 'sine';
        gain.gain.setValueAtTime(0, ac.currentTime+delay);
        gain.gain.linearRampToValueAtTime(0.35, ac.currentTime+delay+0.05);
        gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime+delay+0.8);
        osc.start(ac.currentTime+delay); osc.stop(ac.currentTime+delay+0.8);
      });
    } catch(_) {}
  }

  function onFinish() {
    timerRunning = false;
    if (interval) clearInterval(interval);
    startStopBtn.textContent = '▶ Start';
    startStopBtn.classList.remove('running');
    display.textContent = '00:00';
    playBeep();
    if ('Notification' in window && Notification.permission === 'granted')
      new Notification('🐣 Session complete!', { body: 'Your learning session is done.', icon: '/favicon.svg' });
  }

  startStopBtn.addEventListener('click', () => {
    if (timerRunning) {
      clearInterval(interval); timerRunning = false;
      startStopBtn.textContent = '▶ Start'; startStopBtn.classList.remove('running');
    } else {
      // sync from input before starting
      const val = parseFloat(timerInput.value);
      if (!isNaN(val) && val > 0) timeLeft = Math.round(val * 60);
      if (timeLeft <= 0) timeLeft = 5 * 60;
      timerRunning = true;
      startStopBtn.textContent = '⏸ Pause'; startStopBtn.classList.add('running');
      interval = setInterval(() => {
        timeLeft--; display.textContent = fmt(timeLeft);
        if (timeLeft <= 0) onFinish();
      }, 1000);
    }
  });

  if ('Notification' in window && Notification.permission !== 'granted') {
    notifBtn.style.display = 'inline';
    notifBtn.addEventListener('click', async () => {
      if ((await Notification.requestPermission()) === 'granted') notifBtn.style.display = 'none';
    });
  }
</script>

</body>
</html>
